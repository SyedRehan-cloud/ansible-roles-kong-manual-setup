_format_version: "3.0"
_transform: true

services:
  - name: user-service
    url: http://{{ backend_host }}:5678

    plugins:
      - name: rate-limiting
        config:
          minute: 5
          policy: local

      - name: jwt
        config:
          key_claim_name: iss
          claims_to_verify:
            - exp

    routes:
      - name: user-route
        paths:
          - /users
        strip_path: true

  - name: order-service
    url: http://{{ backend_host }}:5678

    plugins:
      - name: rate-limiting
        config:
          minute: 5
          policy: local

    routes:
      - name: order-route
        paths:
          - /orders
        strip_path: true

  - name: payment-service
    url: http://{{ backend_host }}:5678

    plugins:
      - name: http-log
        config:
          http_endpoint: http://mockbin.org/bin/log
          method: POST
          timeout: 1000

    routes:
      - name: payment-route
        paths:
          - /payments
        strip_path: true
